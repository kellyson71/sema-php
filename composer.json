{
  "name": "sema/requerimentos",
  "description": "Sistema de Requerimentos de Alvarás Ambientais - SEMA Pau dos Ferros/RN",
  "type": "project",
  "require": {
    "php": ">=7.4",
    "phpmailer/phpmailer": "^7.0",
    "phpoffice/phpword": "^1.3",
    "endroid/qr-code": "^6.0",
    "gumlet/php-image-resize": "^2.1",
    "mpdf/mpdf": "^8.2",
    "spomky-labs/otphp": "^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Sema\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sema\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
